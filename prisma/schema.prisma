generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  cnpj          String         @unique
  created_at    DateTime?      @default(now())
  /// Custom hostname for this restaurant's digital menu (selfhub-web), e.g. `cardapio.boteco-do-ze.com.br` —
  /// no protocol/port. Optional: restaurants that only use selfhub-admin don't need one. Resolved by
  /// `GET /restaurants/by-domain/:domain` — see docs/digital-menu-feature.md §0.
  domain        String?        @unique
  /// Weekly opening hours, one entry per weekday (0=Sunday..6=Saturday). Empty/absent means
  /// "always open" — existing restaurants aren't suddenly blocked from taking orders just
  /// because they haven't configured this yet. See `src/shared/utils/businessHours.ts`.
  businessHours BusinessHoursDay[]
  /// Ordered list of marketing/menu sections rendered at the top of the digital menu's
  /// home page (banner carousels, curated product carousels). Order = array order, both
  /// for sections and for the banners/items inside each one. Empty/absent means the home
  /// page shows no marketing sections — just search + categories. See
  /// `src/modules/homeSections/HomeSectionsService.ts`.
  homeSections  HomeSection[]
  profiles      Profile[]
  categories    Category[]
  orders        Order[]
  devices       Device[]
  deliveryZones DeliveryZone[]
  tables        Table[]
  walls         Wall[]
  cashSessions  CashSession[]
  bills         Bill[]
  comandas      Comanda[]
  customers     Customer[]

  @@map("restaurants")
}

type BusinessHoursDay {
  /// 0=Sunday … 6=Saturday — matches JS `Date.getDay()`.
  dayOfWeek Int
  isOpen    Boolean @default(true)
  /// "HH:mm", required when `isOpen` is true.
  openTime  String?
  closeTime String?
}

/// A slide in a `HomeSection` of type `BANNER_CAROUSEL`. Plain `imageUrl` string —
/// same convention as `Product.imageUrl`/`Category.iconUrl`, no upload pipeline.
type HomeBannerSlide {
  /// Client-generated, stable across edits (not a Mongo ObjectId) — composite types
  /// embedded in an array don't get one automatically.
  id            String
  imageUrl      String
  badgeText     String?
  title         String?
  subtitle      String?
  ctaLabel      String?
  /// Tapping the banner opens this product, if set (mutually exclusive with ctaCategoryId).
  ctaProductId  String? @db.ObjectId
  ctaCategoryId String? @db.ObjectId
}

/// One curated product inside a `HomeSection` of type `PRODUCT_CAROUSEL`. `badgeText`/
/// `compareAtPrice` are purely decorative — the real order price always comes from the
/// product catalog (see CreateOrderService), never from here.
type HomeCarouselItem {
  id             String
  productId      String  @db.ObjectId
  badgeText      String?
  compareAtPrice Float?
}

/// One section of the digital menu home page, e.g. a hero banner carousel or a curated
/// "Ofertas do Dia" product carousel. See `src/modules/homeSections/HomeSectionsService.ts`.
type HomeSection {
  id           String
  /// "BANNER_CAROUSEL" | "PRODUCT_CAROUSEL"
  type         String
  /// Section heading shown above it — ignored for BANNER_CAROUSEL.
  title        String?
  /// "CARD" | "CIRCLE" | "FEATURED" — only meaningful for PRODUCT_CAROUSEL.
  displayStyle String?
  isActive     Boolean            @default(true)
  banners      HomeBannerSlide[]
  items        HomeCarouselItem[]
}

model Device {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  macAddress   String     @unique
  restaurantId String     @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime   @default(now())

  @@map("devices")
}

enum ProfileRole {
  ADMIN
  MANAGER
  WAITER
  CASHIER
}

model Profile {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  lastname        String      @default("")
  email           String      @unique
  password        String
  restaurantId    String      @db.ObjectId
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime?
  updatedByUserId String?     @db.ObjectId
  role            ProfileRole @default(WAITER)
  /// `false` blocks login (soft-deleted "team member" — see StaffService). Login itself is rejected for inactive profiles regardless of password correctness.
  isActive        Boolean     @default(true)
  /// 4-digit PIN (hashed, like `password`), only meaningful for MANAGER/ADMIN. Used to authorize over-alçada discounts at the Caixa without forcing the cashier to log out — see StaffService#verifyPin.
  pin             String?

  categoriesEdited Category[]     @relation("CategoryLastEditor")
  productsCreated  Product[]      @relation("ProductCreator")
  productsEdited   Product[]      @relation("ProductLastEditor")
  refreshTokens    RefreshToken[]
}

/**
 * Opaque refresh tokens (never JWTs — they carry no claims, just an
 * unguessable random value) used to obtain a new access token once it
 * expires. Stored hashed (`tokenHash`), never in plaintext, so a DB read
 * alone can't be used to impersonate a session.
 * Rotation: every successful refresh revokes the token used and issues a
 * brand new one (`replacedByHash` links them for traceability). Presenting
 * an already-revoked token again is treated as token theft/reuse and
 * revokes every active token for that profile — see RefreshTokenService.
 */
model RefreshToken {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash      String    @unique
  profileId      String    @db.ObjectId
  profile        Profile   @relation(fields: [profileId], references: [id])
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedByHash String?
  createdAt      DateTime  @default(now())

  @@index([profileId])
}

model Category {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  iconUrl        String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurantId   String     @db.ObjectId
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  lastEditedById String     @db.ObjectId
  lastEditedBy   Profile    @relation("CategoryLastEditor", fields: [lastEditedById], references: [id])
  products       Product[]
}

model Product {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  price               Float
  imageUrl            String
  description         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  categoryId          String               @db.ObjectId
  category            Category             @relation(fields: [categoryId], references: [id])
  createdById         String               @db.ObjectId
  createdBy           Profile              @relation("ProductCreator", fields: [createdById], references: [id])
  lastEditedById      String               @db.ObjectId
  lastEditedBy        Profile              @relation("ProductLastEditor", fields: [lastEditedById], references: [id])
  orderItems          OrderItem[]
  customizationGroups CustomizationGroup[]
}

model CustomizationGroup {
  id        String                @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  min       Int
  max       Int
  productId String                @db.ObjectId
  product   Product               @relation(fields: [productId], references: [id])
  options   CustomizationOption[]
}

model CustomizationOption {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  price                Float
  customizationGroupId String             @db.ObjectId
  customizationGroup   CustomizationGroup @relation(fields: [customizationGroupId], references: [id])
}

enum OrderStatus {
  CREATED
  PREPARING
  COMING
  IN_ROUTE
  DELIVERED
  FINISHED
  CANCELED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  MONEY
  UNKNOWN
}

enum OrderOrigin {
  DELIVERY
  PICKUP
  LOCAL
}

model Order {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber           String
  status                OrderStatus   @default(CREATED)
  origin                OrderOrigin   @default(LOCAL)
  orderedAt             DateTime      @default(now())
  preparedAt            DateTime?
  deliveredAt           DateTime?
  finishedAt            DateTime?
  canceledAt            DateTime?
  tableNumber           String
  waiterNumber          String
  address               Json?
  deliveryFee           Float?
  estimatedDeliveryTime Int?
  deliveryZoneId        String?       @db.ObjectId
  deliveryZone          DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  totalValue            Float
  paymentMethod         PaymentMethod
  restaurantId          String        @db.ObjectId
  restaurant            Restaurant    @relation(fields: [restaurantId], references: [id])
  items                 OrderItem[]
  /// Set once this order has been aggregated into a Caixa `Bill` (see BillService#getOrCreateBill).
  /// Plain scalar, no `@relation` — same loose-coupling convention as `tableNumber`/`Table.number`.
  /// Lets the bill-aggregation query cheaply exclude orders that already belong to a (open or closed) Bill.
  billId                String?       @db.ObjectId
  /// The comanda this order was placed against — required for `origin: LOCAL` orders created after the
  /// comanda migration (see selfhub-admin/docs/comandas-backend-spec.md). Null for DELIVERY/PICKUP and for
  /// LOCAL orders created before this field existed (not backfilled).
  comandaId             String?       @db.ObjectId
  /// Denormalized from `Comanda.number` at creation time, same convention as the other denormalized
  /// "*Name"/"*Number" fields in this schema — lets the front display it without an extra lookup.
  comandaNumber         Int?
  /// The customer who placed this order, identified by CPF (see `Customer`). Optional because
  /// orders created before this feature existed have it absent in Mongo (not backfilled).
  customerId            String?       @db.ObjectId
  customer              Customer?     @relation(fields: [customerId], references: [id])
  /// Denormalized snapshot of `Customer.name`/`cpf`/`phone` at order time, same convention as the
  /// other denormalized "*Name"/"*Number" fields in this schema — survives later edits to the customer record.
  customerName          String?
  customerCpf           String?
  customerPhone         String?

  @@index([origin])
  @@index([restaurantId, tableNumber, billId])
  @@index([restaurantId, comandaId])
  @@index([restaurantId, customerId])
}

/**
 * A customer identified by CPF, scoped per restaurant — the same person ordering from two
 * different restaurants on the platform gets two separate `Customer` records. Created/updated
 * via upsert-by-CPF inside `CreateOrderService` the first time someone places an order with that
 * CPF; never created directly from selfhub-admin (see CustomerService — view/edit only, no create).
 * `cpf`/`phone` are stored digits-only (no mask) — formatting is a UI-only concern.
 */
model Customer {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  cpf          String
  name         String
  phone        String
  /// Last known delivery address, kept up to date on every DELIVERY order. Null if the customer
  /// has only ever placed LOCAL/PICKUP orders.
  address      Json?
  restaurantId String     @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  orders       Order[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, cpf])
  @@index([restaurantId, name])
}

model DeliveryZone {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  deliveryFee   Float
  estimatedTime Int?
  isActive      Boolean    @default(true)
  restaurantId  String     @db.ObjectId
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  lastEditedBy  String     @db.ObjectId
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  orders        Order[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
}

model OrderItem {
  id             String                         @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String                         @db.ObjectId
  productId      String                         @db.ObjectId
  quantity       Int
  imageUrl       String?
  observation    String?
  ratingStar     Float?
  order          Order                          @relation(fields: [orderId], references: [id])
  product        Product                        @relation(fields: [productId], references: [id])
  customizations OrderItemCustomizationOption[]
}

model OrderItemCustomizationOption {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId     String    @db.ObjectId
  name            String
  additionalPrice Float
  quantity        Int
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id])
}

enum TableStatus {
  free
  occupied
  reserved
  cleaning
}

type Position {
  x Float
  y Float
}

type TableSize {
  width  Float
  height Float
}

/**
 * A table on the table-layout editor's floor plan. `status` reflects the
 * operational state (open order, etc.) and is intentionally never written
 * by the layout save endpoint — see TableLayoutService. `position` is
 * `null` while the table exists but hasn't been placed on the floor plan
 * yet (shown in the editor's "available tables" list). `size` is `null`
 * when the editor should fall back to its default table dimensions.
 */
model Table {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  number       Int
  status       TableStatus @default(free)
  position     Position?
  size         TableSize?
  restaurantId String      @db.ObjectId
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([restaurantId, number])
}

/**
 * A wall drawn on the table-layout editor's floor plan: a straight segment
 * from `start` to `end` (any angle — no more horizontal/vertical/custom
 * distinction). Purely visual, unrelated to orders. Coordinates/thickness
 * are canvas pixel values from the editor, stored/returned as-is with no
 * unit conversion or geometric validation.
 */
model Wall {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  start        Position
  end          Position
  thickness    Float      @default(8)
  restaurantId String     @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ---------------------------------------------------------------------------
// Comandas — see selfhub-admin/docs/comandas-backend-spec.md
// ---------------------------------------------------------------------------

enum ComandaStatus {
  OPEN
  CLOSED
}

enum ComandaOpenedBy {
  STAFF
  CUSTOMER
}

/**
 * A physical "comanda" card handed to a guest. `number` is whatever's
 * printed on the card — there's no pre-registered range or auto-increment.
 * It's only unique among comandas currently `OPEN` in the restaurant: once
 * `CLOSED`, the number is recycled for a future guest, so uniqueness is
 * enforced in ComandaService, not via a DB constraint (a `@@unique` would
 * wrongly block reuse). A table can have any number of `OPEN` comandas at
 * once — there's no 1:1 table/comanda relationship.
 */
model Comanda {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  restaurantId String          @db.ObjectId
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id])
  number       Int
  tableNumber  Int
  status       ComandaStatus   @default(OPEN)
  openedAt     DateTime        @default(now())
  closedAt     DateTime?
  /// Null when `openedBy: CUSTOMER` — a self-checkin (digital menu QR code) has no `Staff` behind it.
  openedById   String?         @db.ObjectId
  /// Denormalized name of `openedById`, same convention as `CashSession.cashierName`. `"Self-Service"` for `CUSTOMER`.
  openedByName String
  /// `STAFF` (garçom/caixa abriu via `POST /comandas`) vs `CUSTOMER` (cliente via `POST /tables/:tableNumber/comandas/self-checkin`).
  openedBy     ComandaOpenedBy @default(STAFF)
  bills        Bill[]

  @@index([restaurantId, number, status])
  @@index([restaurantId, tableNumber, status])
}

// ---------------------------------------------------------------------------
// Caixa (frente de loja) — see selfhub-admin/docs/caixa-backend-spec.md
// ---------------------------------------------------------------------------

enum CashSessionStatus {
  OPEN
  CLOSED
}

/**
 * A cashier's shift. Only one `OPEN` session is allowed per `Staff` at a
 * time (enforced in CashSessionService, not at the DB level). Every `Bill`
 * closed during the shift, plus every sangria/suprimento (`CashMovement`),
 * is linked back to the session that was open when it happened.
 */
model CashSession {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  restaurantId   String            @db.ObjectId
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id])
  cashierId      String            @db.ObjectId
  /// Denormalized for direct display on the front — see spec.
  cashierName    String
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  openingAmount  Float
  closingAmount  Float?
  /// openingAmount + CASH sales - withdrawals + supplies, computed on close. Card/Pix never touch the physical drawer, so only CASH counts.
  expectedAmount Float?
  /// closingAmount - expectedAmount, computed on close.
  difference     Float?
  status         CashSessionStatus @default(OPEN)
  /// Who actually closed the register — usually `cashierId`, but kept separate to cover a MANAGER/ADMIN closing someone else's shift.
  closedById     String?           @db.ObjectId
  closedByName   String?
  movements      CashMovement[]
  bills          Bill[]

  @@index([restaurantId, cashierId, status])
}

enum CashMovementType {
  WITHDRAWAL
  SUPPLY
}

/**
 * A sangria (`WITHDRAWAL`) or suprimento (`SUPPLY`) registered during a `CashSession`.
 */
model CashMovement {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  cashSessionId String           @db.ObjectId
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id])
  type          CashMovementType
  amount        Float
  reason        String
  createdAt     DateTime         @default(now())
  createdById   String           @db.ObjectId
  /// Denormalized name of `createdById`, same convention as `CashSession.cashierName`.
  /// Optional because rows created before this field existed have it absent
  /// in Mongo (no migration backfilled them) — see CashSessionService's formatter.
  createdByName String?

  @@index([cashSessionId])
}

enum BillStatus {
  OPEN
  PAID
  CANCELED
}

/**
 * One aggregated line of a `Bill`, summed across every `Order`/`OrderItem` for the same product.
 */
type BillItem {
  productId   String @db.ObjectId
  productName String
  quantity    Int
  unitPrice   Float
  total       Float
}

/**
 * The aggregated tab for a single comanda: sums every open `Order` placed
 * against that comanda (see `Order.comandaId`) into `items`/`subtotal`, then
 * applies discount/service-fee on top to reach `total`. Matched by
 * `comandaId` — **not** by table, since a table can have several comandas
 * open at once (see selfhub-admin/docs/comandas-backend-spec.md). `tableNumber`
 * is kept denormalized purely for display ("Comanda 53 — Mesa 12").
 */
model Bill {
  id                   String          @id @default(auto()) @map("_id") @db.ObjectId
  restaurantId         String          @db.ObjectId
  restaurant           Restaurant      @relation(fields: [restaurantId], references: [id])
  /// Optional only because Bills created before the comanda migration have it absent in Mongo
  /// (no migration backfilled them — there's no comanda to backfill from). Every Bill created
  /// by BillService#getOrCreateBill going forward always has this set.
  comandaId            String?         @db.ObjectId
  comanda              Comanda?        @relation(fields: [comandaId], references: [id])
  /// Denormalized from `Comanda.number` at creation time — what the cashier typed in. Same
  /// "absent on pre-migration rows" caveat as `comandaId`.
  comandaNumber        Int?
  /// Denormalized from `Comanda.tableNumber` — display only, not used to match orders anymore.
  /// `0` for Bills created from a DELIVERY/PICKUP order via `BillService#getOrCreateBillForOrder`
  /// — those have no table, see `orderNumber`/`customerName` instead.
  tableNumber          Int
  /// Denormalized from `Order.orderNumber` — set only on Bills created via `getOrCreateBillForOrder`
  /// (DELIVERY/PICKUP), null on comanda Bills. Lets the front display it without an extra lookup.
  orderNumber          String?
  /// Denormalized from `Order.customerName`, same convention/caveat as `orderNumber`.
  customerName         String?
  cashSessionId        String          @db.ObjectId
  cashSession          CashSession     @relation(fields: [cashSessionId], references: [id])
  orderIds             String[]        @db.ObjectId
  items                BillItem[]
  subtotal             Float
  discountAmount       Float           @default(0)
  discountPercent      Float?
  /// `Staff.id` of the MANAGER/ADMIN who authorized a >10% discount via PIN. Null below that alçada.
  discountApprovedById String?         @db.ObjectId
  serviceFeeAmount     Float           @default(0)
  serviceFeePercent    Float?
  /// The delivered order's `Order.deliveryFee`, carried onto the bill total. Always 0 on comanda Bills.
  deliveryFeeAmount    Float           @default(0)
  total                Float
  status               BillStatus      @default(OPEN)
  closedAt             DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  payments             Payment[]
  fiscalDocument       FiscalDocument?

  @@index([restaurantId, comandaId, status])
}

/**
 * `CASH`/`CARD` are confirmed manually by the cashier (no TEF). Only `PIX` starts `PENDING` until the Mercado Pago webhook confirms it.
 */
enum CashierPaymentMethod {
  CASH
  CARD
  PIX
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model Payment {
  id            String               @id @default(auto()) @map("_id") @db.ObjectId
  billId        String               @db.ObjectId
  bill          Bill                 @relation(fields: [billId], references: [id])
  method        CashierPaymentMethod
  amount        Float
  status        PaymentStatus        @default(PENDING)
  /// Mercado Pago payment id — also the idempotency key for the webhook (PIX only).
  pixTxId       String?
  /// Base64 PNG, same as Mercado Pago's `qr_code_base64` (PIX only).
  pixQrCode     String?
  /// EMV copia-e-cola string, same as Mercado Pago's `qr_code` (PIX only).
  pixCopyPaste  String?
  pixPaidAt     DateTime?
  createdAt     DateTime             @default(now())
  createdById   String               @db.ObjectId
  /// Denormalized name of `createdById`, same convention as `CashSession.cashierName`.
  /// Optional because rows created before this field existed have it absent
  /// in Mongo (no migration backfilled them) — see PaymentService's formatter.
  createdByName String?

  @@index([billId])
  @@index([pixTxId])
}

enum FiscalDocumentStatus {
  PENDING
  ISSUED
  FAILED
}

/**
 * NFC-e issuance for a fully-paid `Bill`, via a third-party provider (see `providers/focusNfe.ts`).
 */
model FiscalDocument {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  billId            String               @unique @db.ObjectId
  bill              Bill                 @relation(fields: [billId], references: [id])
  status            FiscalDocumentStatus @default(PENDING)
  providerInvoiceId String?
  danfeUrl          String?
  customerEmail     String?
  customerPhone     String?
  customerCpf       String?
  issuedAt          DateTime?
  error             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}
